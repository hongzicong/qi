ninja_required_version = 1.3
cxx = c++
nvcc = /usr/local/cuda/bin/nvcc

cflags = -pthread -Wno-unused-result -Wsign-compare -Wunreachable-code -DNDEBUG -g -fwrapv -O3 -Wall -O3 -fno-omit-frame-pointer -mno-omit-leaf-frame-pointer -fPIC -fPIC '-I/workspace/桌面/qi/src/qi/quantization/csrc/int8_w8a8' '-I/workspace/桌面/qi/src/qi/quantization/third_party/cutlass/include' '-I/workspace/桌面/qi/src/qi/quantization/third_party/cutlass/tools/util/include' -I/opt/venv/lib/python3.10/site-packages/torch/include -I/opt/venv/lib/python3.10/site-packages/torch/include/torch/csrc/api/include -I/usr/local/cuda/include -I/opt/venv/include -I/root/.local/share/uv/python/cpython-3.10.20-linux-aarch64-gnu/include/python3.10 -c
post_cflags = -O3 -std=c++17 -DTORCH_API_INCLUDE_EXTENSION_H -DTORCH_EXTENSION_NAME=_int8_w8a8_ops
cuda_cflags = '-I/workspace/桌面/qi/src/qi/quantization/csrc/int8_w8a8' '-I/workspace/桌面/qi/src/qi/quantization/third_party/cutlass/include' '-I/workspace/桌面/qi/src/qi/quantization/third_party/cutlass/tools/util/include' -I/opt/venv/lib/python3.10/site-packages/torch/include -I/opt/venv/lib/python3.10/site-packages/torch/include/torch/csrc/api/include -I/usr/local/cuda/include -I/opt/venv/include -I/root/.local/share/uv/python/cpython-3.10.20-linux-aarch64-gnu/include/python3.10 -c
cuda_post_cflags = -D__CUDA_NO_HALF_OPERATORS__ -D__CUDA_NO_HALF_CONVERSIONS__ -D__CUDA_NO_BFLOAT16_CONVERSIONS__ -D__CUDA_NO_HALF2_OPERATORS__ --expt-relaxed-constexpr --compiler-options ''"'"'-fPIC'"'"'' -O3 --use_fast_math --expt-relaxed-constexpr -std=c++17 -DTORCH_API_INCLUDE_EXTENSION_H -DTORCH_EXTENSION_NAME=_int8_w8a8_ops -gencode=arch=compute_87,code=sm_87
cuda_dlink_post_cflags = 
sycl_dlink_post_cflags = 
ldflags = 

rule compile
  command = $cxx -MMD -MF $out.d $cflags -c $in -o $out $post_cflags
  depfile = $out.d
  deps = gcc

rule cuda_compile
  depfile = $out.d
  deps = gcc
  command = $nvcc -MD -MF $out.d $cuda_cflags -c $in -o $out $cuda_post_cflags







build /workspace/桌面/qi/build/temp.linux-aarch64-cpython-310/workspace/桌面/qi/src/qi/quantization/csrc/int8_w8a8/bindings.o: compile /workspace/桌面/qi/src/qi/quantization/csrc/int8_w8a8/bindings.cpp
build /workspace/桌面/qi/build/temp.linux-aarch64-cpython-310/workspace/桌面/qi/src/qi/quantization/csrc/int8_w8a8/cutlass_int8_rowwise.o: cuda_compile /workspace/桌面/qi/src/qi/quantization/csrc/int8_w8a8/cutlass_int8_rowwise.cu
build /workspace/桌面/qi/build/temp.linux-aarch64-cpython-310/workspace/桌面/qi/src/qi/quantization/csrc/int8_w8a8/cutlass_int8_rowwise_t64x128.o: cuda_compile /workspace/桌面/qi/src/qi/quantization/csrc/int8_w8a8/cutlass_int8_rowwise_t64x128.cu
build /workspace/桌面/qi/build/temp.linux-aarch64-cpython-310/workspace/桌面/qi/src/qi/quantization/csrc/int8_w8a8/quantize_int8.o: cuda_compile /workspace/桌面/qi/src/qi/quantization/csrc/int8_w8a8/quantize_int8.cu








